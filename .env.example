BOOKING_CAPACITY=100
BOOKING_GROUP1_CAPACITY=50
# Dev/preview only: set to true locally to preview sold-out / waitlist UI
# BOOKING_FORCE_SOLD_OUT=true
# Optional: override waitlist count shown in the sold-out badge (e.g. 3 → "Waitinglist: +3")
# BOOKING_FORCE_WAITLIST_COUNT=3
BOOKING_AVAILABILITY_SOURCE_URL=
BOOKING_NOTIFY_EMAILS=contact@resulam.com
BOOKING_STATS_KEY=change-me-in-production
EVENT_DATE=2026-08-09
BOOKING_REMINDER_CRON_KEY=change-me-in-production

# Admin Google sign-in (OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
ADMIN_ALLOWED_EMAILS=contact@resulam.com,tchamna@gmail.com,deusiar@gmail.com,mirabelle.noumbissie@gmail.com,axelle.ngamani@gmail.com,djiadeuchristian@gmail.com
ADMIN_SESSION_SECRET=change-me-in-production
# Public site URL used for OAuth redirect (optional if host headers are correct)
# NEXT_PUBLIC_APP_URL=https://resulam-france-2026.azurewebsites.net

AUTH_SMTP_HOST=smtp.gmail.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=your-gmail-address
# Gmail app password: 16 chars, no spaces (Google shows groups of four)
AUTH_SMTP_PASSWORD=your-gmail-app-password
AUTH_SMTP_FROM=Resulam France 2026 <contact@resulam.com>
AUTH_SMTP_USE_TLS=true

